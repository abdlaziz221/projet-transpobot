{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-native",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@screens/*": ["src/screens/*"],
      "@navigation/*": ["src/navigation/*"],
      "@store": ["src/store.ts"],
      "@types/*": ["src/types/*"]
    }
  },
  "include": ["App.tsx", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
